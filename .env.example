# Copy to .env and fill in your values. Never commit .env to source control.

# PostgreSQL connection string (required)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# xAI / Grok API key for Grokky AI features (required for AI routes)
XAI_API_KEY=your_xai_api_key_here

# Port for the Flask dev server (default: 8000)
PORT=8000

# Enable Flask debug mode (set to "1" only in local dev, never in production)
FLASK_DEBUG=0

# Comma-separated list of allowed frontend origins for CORS
# In production, set this to your actual frontend URL
ALLOWED_ORIGINS=http://localhost:5173
