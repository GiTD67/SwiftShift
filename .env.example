# PostgreSQL connection string (Railway provides this automatically as DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/swiftshift

# Comma-separated list of allowed CORS origins
# For production: https://swiftshift.work
# For local dev: http://localhost:5173
ALLOWED_ORIGINS=https://swiftshift.work

# xAI API key for Grok (get yours at console.x.ai)
XAI_API_KEY=xai-...

# Port to listen on (Railway sets this automatically)
PORT=8000

# Secret used to sign login session cookies. MUST be set in production (otherwise
# sessions reset on restart and differ across workers). Generate: openssl rand -hex 32
SECRET_KEY=

# Transactional email (Resend). Without RESEND_API_KEY, signup verification and
# password-reset emails are silently skipped (the rest of the app still works).
# The RESEND_FROM domain must be verified in your Resend dashboard.
RESEND_API_KEY=re_...
RESEND_FROM=SwiftShift <noreply@swiftshift.work>

# Public origin used to build links in emails (verification + password reset).
APP_BASE_URL=https://swiftshift.work

# Shared rate-limit store so limits hold across gunicorn workers. Without it the
# limiter is per-process (N workers = N× the configured limit). Set to your
# Redis URL in production.
REDIS_URL=
